{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./ts",
    "rootDir": "./ts"
  },
  "include": ["ts/**/*.ts"],
  "exclude": ["node_modules"]
}
